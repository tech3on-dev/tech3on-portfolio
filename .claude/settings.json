      "Bash(npx --yes netlify-cli@latest --version)",
      "Bash(npx netlify *)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\\\\n\" https://tech3on-portfolio.netlify.app)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\\\\n\" https://tech3on-portfolio.netlify.app/sitemap.xml)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\\\\n\" -X POST https://tech3on-portfolio.netlify.app/api/contact -H \"Content-Type: application/json\" -d '{}')"
    ]
  }
}
