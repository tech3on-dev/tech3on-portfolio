# ------------------------------------------------------------------
# TECH3ON — Environment Variables
# Copy this file to `.env.local` for local development and configure
# the same variables in your Vercel project settings for production.
# ------------------------------------------------------------------

# Public site URL (used for canonical URLs, sitemap, OG tags).
# No trailing slash.
NEXT_PUBLIC_SITE_URL=https://www.tech3on.com

# Calendly scheduling link shown in the contact section.
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/tech3on/consultation

# ------------------------------------------------------------------
# Contact form delivery (optional — see src/app/api/contact/route.ts)
# Uncomment and configure to deliver leads via email or a CRM.
# ------------------------------------------------------------------

# Resend (https://resend.com) — recommended for transactional email
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# CONTACT_TO_EMAIL=hello@tech3on.com

# Alternatively, post submissions to a CRM / Slack / webhook
# CONTACT_WEBHOOK_URL=https://hooks.example.com/xxxx
